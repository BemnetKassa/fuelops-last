// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String         @id @default(uuid())
  name             String
  email            String         @unique
  password         String
  phone            String         @unique
  role             UserRole
  licensePlate     String?
  drivingLicenseId String?
  carType          String?
  fuelType         String?
  createdAt        DateTime       @default(now())
  reservations     Reservation[]  @relation("UserReservations")
  notifications    Notification[]
  reports          Report[]
}

model Admin {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  email     String   @unique
  password  String
  phone     String?
  createdAt DateTime @default(now())
}

model StationAdmin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  station   Station? @relation(fields: [stationId], references: [id])
  stationId String?
  createdAt DateTime @default(now())
}

model Station {
  id       String @id @default(uuid())
  name     String @unique
  location String

  latitude  Float
  longitude Float

  admins       StationAdmin[]
  reservations Reservation[]
  reports      Report[]
  createdAt    DateTime       @default(now())
}

model Reservation {
  id         String            @id @default(uuid())
  driver     User              @relation("UserReservations", fields: [driverId], references: [id])
  driverId   String
  station    Station           @relation(fields: [stationId], references: [id])
  stationId  String
  fuelAmount Float
  fuelType   FuelType
  status     ReservationStatus @default(PENDING)
  expiresAt  DateTime
  createdAt  DateTime          @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
  DRIVER
  STATION_ADMIN
  SUPER_ADMIN
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum FuelType {
  PETROL
  DIESEL
}

model Report {
  id          String         @id @default(uuid())
  reporter    User           @relation(fields: [reporterId], references: [id])
  reporterId  String
  station     Station?       @relation(fields: [stationId], references: [id])
  stationId   String?
  category    ReportCategory
  title       String
  description String
  status      ReportStatus   @default(OPEN)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

enum ReportCategory {
  STATION_NOT_WORKING
  POOR_SERVICE
  BRIBERY
  BLACK_MARKET
  SAFETY
  OTHER
}

enum ReportStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}
